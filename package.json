{
  "name": "minimal-commerce",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:e2e": "next dev --webpack -H 127.0.0.1 -p 3000",
    "dev:turbo": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "eslint . --fix",
    "test": "node -e \"require('fs').rmSync('.tmp-tests',{recursive:true,force:true})\" && tsc -p tsconfig.test.json && node scripts/run-node-tests.mjs .tmp-tests/tests",
    "e2e": "playwright test",
    "e2e:staging": "playwright test e2e/staging-real.spec.ts --project=chromium",
    "e2e:production": "playwright test e2e/staging-real.spec.ts --project=chromium",
    "e2e:checkout-real": "playwright test e2e/checkout-real.spec.ts --project=chromium",
    "e2e:headed": "playwright test --headed",
    "e2e:install": "playwright install chromium",
    "obs:smoke": "node scripts/observability-smoke.mjs",
    "check": "npm run lint && npm run typecheck && npm run build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.94.0",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.31.0",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
